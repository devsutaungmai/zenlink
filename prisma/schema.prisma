enum IncompleteProfileBehavior {
  SHOW_WARNING
  BLOCK_SCHEDULING
  NONE
}

model EmployeeSettings {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation("EmployeeSettings", fields: [businessId], references: [id], onDelete: Cascade)

  // Required Profile Fields
  requireFirstName          Boolean                   @default(true)
  requireLastName           Boolean                   @default(true)
  requireBirthday           Boolean                   @default(true)
  requireGender             Boolean                   @default(true)
  requireAddress            Boolean                   @default(false)
  requirePhone              Boolean                   @default(true)
  requireEmail              Boolean                   @default(false)
  requireSocialSecurityNo   Boolean                   @default(false)
  requireEmployeeNo         Boolean                   @default(true)
  requireDateOfHire         Boolean                   @default(true)
  requireHoursPerMonth      Boolean                   @default(true)
  requireBankAccount        Boolean                   @default(false)
  requireDepartment         Boolean                   @default(true)
  requireEmployeeGroup      Boolean                   @default(false)
  requireRole               Boolean                   @default(false)
  requireSalaryRate         Boolean                   @default(false)
  incompleteProfileBehavior IncompleteProfileBehavior @default(SHOW_WARNING)

  // Default Settings for New Employees
  defaultDepartmentId    String?
  defaultEmployeeGroupId String?
  defaultRoleId          String?

  // Visibility & Access Rules
  rolesCanViewEmployees       String[] @default([])
  employeesCanSeeContactInfo  Boolean  @default(true)
  limitVisibilityByDepartment Boolean  @default(false)

  // Onboarding Rules
  onboardingRequiredFields String[] @default([])
  requireManagerApproval   Boolean  @default(false)
  sendMissingInfoReminder  Boolean  @default(true)
  reminderDaysAfterHire    Int      @default(7)

  // General HR Preferences
  defaultLanguage              String   @default("en")
  employeeNotificationsEnabled Boolean  @default(true)
  employeesCanEditProfile      Boolean  @default(true)
  employeeEditableFields       String[] @default(["phone", "address", "profilePhoto"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

// ============================================
// CONTRACT RULES MODULE
// ============================================

enum EmploymentType {
  FULL_TIME
  PART_TIME
  SEASONAL_TEMPORARY
  HOURLY
  MONTHLY_SALARY
}

enum OvertimeExemption {
  MANAGERIAL_POSITION
  HIGHLY_INDEPENDENT_POSITION
}

enum ContractWarningType {
  YELLOW_IN_PLANNER
  EMAIL_NOTIFICATION
  BLOCK_SCHEDULING
}

model LaborLawProfile {
  id                 String            @id @default(cuid())
  name               String
  description        String?
  laborLawSettingsId String?
  businessId         String
  isDefault          Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  business           Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  laborLawSettings   LaborLawSettings? @relation(fields: [laborLawSettingsId], references: [id])
  contractTypes      ContractType[]

  @@unique([name, businessId])
  @@index([businessId])
  @@index([laborLawSettingsId])
}

model ContractType {
  id                           String              @id @default(cuid())
  name                         String
  employmentType               EmploymentType      @default(FULL_TIME)
  defaultFtePercent            Float               @default(100)
  agreedWeeklyHours            Float?
  maxPlannedWeeklyHours        Float?
  overtimeAllowed              Boolean             @default(true)
  overtimeExemptRoleIds        String[]            @default([])
  maxWeekendsPerMonth          Int?
  customBreakMinutes           Int?
  warningType                  ContractWarningType @default(YELLOW_IN_PLANNER)
  notifyManagerOnDeviation     Boolean             @default(false)
  allowSchedulingWithDeviation Boolean             @default(true)
  laborLawProfileId            String
  laborLawProfile              LaborLawProfile     @relation(fields: [laborLawProfileId], references: [id])
  businessId                   String
  business                     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  employees                    Employee[]

  @@unique([name, businessId])
  @@index([businessId])
  @@index([laborLawProfileId])
}

// ============================================
// EVENTS & ANNOUNCEMENTS MODULE
// ============================================

enum EventType {
  MEETING
  TRAINING
  EVENT
}

enum EventStatus {
  DRAFT
  PUBLISHED
}

model Event {
  id           String            @id @default(cuid())
  title        String
  description  String?
  eventDate    DateTime
  startTime    String
  endTime      String?
  location     String?
  type         EventType         @default(EVENT)
  status       EventStatus       @default(DRAFT)
  allDepartments Boolean         @default(false)
  businessId   String
  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  departments  EventDepartment[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([businessId])
  @@index([eventDate])
  @@index([status])
}

model EventDepartment {
  id           String     @id @default(cuid())
  eventId      String
  departmentId String
  event        Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([eventId, departmentId])
  @@index([eventId])
  @@index([departmentId])
}
