generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  firstName           String
  lastName            String
  role                String               @default("USER")
  roleId              String?
  businessId          String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  pin                 String?
  employees           Employee[]
  business            Business             @relation(fields: [businessId], references: [id])
  assignedRole        Role?                @relation(fields: [roleId], references: [id])
  passwordResetTokens PasswordResetToken[]
  notifications       Notification[]       @relation("NotificationRecipientUser")
  signedContracts     Contract[]           @relation("ContractAdminSigner")

  @@index([roleId])
}

// Role model - admin can create custom roles
model Role {
  id          String           @id @default(cuid())
  name        String // e.g., "Admin", "Manager", "Employee"
  description String?
  isSystem    Boolean          @default(false) // System roles can't be deleted
  isDefault   Boolean          @default(false) // Default role for new employees
  businessId  String
  business    Business         @relation(fields: [businessId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       User[]
  permissions RolePermission[]
  employees   EmployeeRole[] // Many-to-many relation with employees
  departments RoleDepartment[] // Many-to-many relation with departments

  @@unique([name, businessId])
  @@index([businessId])
}

// Junction table for Role-Department many-to-many relationship
model RoleDepartment {
  id           String     @id @default(cuid())
  roleId       String
  departmentId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([roleId, departmentId])
  @@index([roleId])
  @@index([departmentId])
}

// Permission model - defines all available permissions
model Permission {
  id          String           @id @default(cuid())
  code        String           @unique // e.g., "employees.view", "employees.create"
  name        String // Human readable name
  description String?
  category    String // e.g., "Employees", "Schedule", "Reports"
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

// Junction table for Role-Permission many-to-many relationship
model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique // OTP code (6 digits)
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  verified  Boolean  @default(false) // New: Track if OTP was verified
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Business {
  id                       String                    @id @default(cuid())
  name                     String
  address                  String
  type                     String
  employeesCount           Int
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  currency                 String                    @default("USD")
  attendances              Attendance[]
  categories               DepartmentCategory[]      @relation("BusinessCategories")
  contracts                Contract[]
  contractTemplates        ContractTemplate[]
  departments              Department[]
  employeeGroups           EmployeeGroup[]
  invitations              Invitation[]
  laborLawSettings         LaborLawSettings[]
  payRules                 PayRule[]
  payrollPeriods           PayrollPeriod[]
  punchClockAccessSettings PunchClockAccessSettings? @relation("PunchClockAccessSettings")
  punchClockProfiles       PunchClockProfile[]
  roles                    Role[]
  salaryCodes              SalaryCode[]
  scheduleTemplates        ScheduleTemplate[]
  shiftTypes               ShiftTypeConfig[]
  users                    User[]
  customers                Customer[]
  products                 Product[]
  invoices                 Invoice[]
  InvoicePaymentTerms      InvoicePaymentTerms[]
  invoiceFormSettings      InvoiceFormSettings?      @relation("InvoiceFormSettings")
  projects                 Project[]
  customerPayments         CustomerPayment[]
  ledgerAccounts           LedgerAccount[]
  ledgerEntries            LedgerEntry[]
  vouchers                 Voucher[]
  productFormSettings      ProductFormSettings?      @relation("ProductFormSettings")
  employeeSettings         EmployeeSettings?         @relation("EmployeeSettings")
  projectFormSettings      ProjectFormSettings?      @relation("ProjectFormSettings")
  customerFormSettings     CustomerFormSettings?     @relation("CustomerFormSettings")
  vatCodes                 VatCode[]
  invoiceGeneralSetting   InvoiceGeneralSetting?   @relation("InvoiceGeneralSetting")
  laborLawProfiles         LaborLawProfile[]
  contractTypes            ContractType[]
  businessLedgerVatCodes   BusinessLedgerAccountVatCode[]
  events                   Event[]
}

model Employee {
  id                  String                  @id @default(cuid())
  userId              String
  firstName           String
  lastName            String
  birthday            DateTime
  sex                 Sex
  socialSecurityNo    String?
  address             String
  mobile              String
  employeeNo          String?
  bankAccount         String
  hoursPerMonth       Float?
  dateOfHire          DateTime
  isTeamLeader        Boolean                 @default(false)
  departmentId        String? // Optional - kept for backward compatibility
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  employeeGroupId     String? // Kept for backward compatibility
  email               String?                 @unique
  profilePhoto        String?
  salaryRate          Float?
  contractTypeId      String?
  ftePercent          Float?
  attendances         Attendance[]
  availabilities      Availability[]
  contractsAsPerson   Contract[]              @relation("ContractPerson")
  contracts           Contract[]
  department          Department?             @relation(fields: [departmentId], references: [id])
  employeeGroup       EmployeeGroup?          @relation("EmployeeToGroup", fields: [employeeGroupId], references: [id])
  user                User                    @relation(fields: [userId], references: [id])
  employeePayRules    EmployeePayRule[]
  notifications       Notification[]          @relation("NotificationRecipient")
  payrollEntries      PayrollEntry[]
  shifts              Shift[]
  fromShiftExchanges  ShiftExchange[]         @relation("FromEmployee")
  toShiftExchanges    ShiftExchange[]         @relation("ToEmployee")
  sickLeaves          SickLeave[]
  sickPayCalculations SickPayCalculation[]
  timeEntries         TimeEntry[]
  workPlans           WorkPlan[]
  functions           EmployeeFunction[]
  departments         EmployeeDepartment[] // Many-to-many relation
  employeeGroups      EmployeeEmployeeGroup[] // Many-to-many relation
  employeeRoles       EmployeeRole[] // Many-to-many relation with roles
  contractType        ContractType?           @relation(fields: [contractTypeId], references: [id])
  shiftRequests       ShiftRequest[]

  @@index([contractTypeId])
}

model EmployeeRole {
  id         String   @id @default(cuid())
  employeeId String
  roleId     String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([employeeId, roleId])
  @@index([employeeId])
  @@index([roleId])
}

model EmployeeDepartment {
  id           String     @id @default(cuid())
  employeeId   String
  departmentId String
  isPrimary    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([employeeId, departmentId])
  @@index([employeeId])
  @@index([departmentId])
}

model EmployeeEmployeeGroup {
  id              String        @id @default(cuid())
  employeeId      String
  employeeGroupId String
  isPrimary       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeGroup   EmployeeGroup @relation(fields: [employeeGroupId], references: [id], onDelete: Cascade)

  @@unique([employeeId, employeeGroupId])
  @@index([employeeId])
  @@index([employeeGroupId])
}

model EmployeeGroup {
  id                    String                  @id @default(cuid())
  name                  String
  hourlyWage            Float
  wagePerShift          Float
  defaultWageType       WageType                @default(HOURLY)
  salaryCode            String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @default(now())
  businessId            String
  contracts             Contract[]
  contractTemplates     ContractTemplate[]
  employees             Employee[]              @relation("EmployeeToGroup")
  business              Business                @relation(fields: [businessId], references: [id])
  functions             DepartmentFunction[]
  employeeGroupPayRules EmployeeGroupPayRule[]
  shifts                Shift[]
  employeesMulti        EmployeeEmployeeGroup[] // Many-to-many relation

  @@unique([name, businessId])
}

model Contract {
  id                      String           @id @default(cuid())
  employeeId              String
  employeeGroupId         String
  contractTemplateId      String
  startDate               DateTime
  endDate                 DateTime?
  contractPersonId        String
  businessId              String
  signedStatus            String?          @default("UNSIGNED")
  signatureData           String?
  signedAt                DateTime?
  signedBy                String?
  adminSignatureData      String?
  adminSignedAt           DateTime?
  adminSignedById         String?
  employeeSignatureData   String?
  employeeSignedAt        DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  business                Business         @relation(fields: [businessId], references: [id])
  contractPerson          Employee         @relation("ContractPerson", fields: [contractPersonId], references: [id])
  contractTemplate        ContractTemplate @relation(fields: [contractTemplateId], references: [id])
  employeeGroup           EmployeeGroup    @relation(fields: [employeeGroupId], references: [id])
  employee                Employee         @relation(fields: [employeeId], references: [id])
  adminSignedBy           User?            @relation("ContractAdminSigner", fields: [adminSignedById], references: [id])
  notifications           Notification[]

  @@index([adminSignedById])
}

model Department {
  id                          String                        @id @default(cuid())
  name                        String
  address                     String
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @default(now())
  address2                    String?
  city                        String
  country                     String
  number                      String?
  phone                       String
  postCode                    String?
  businessId                  String
  business                    Business                      @relation(fields: [businessId], references: [id])
  employees                   Employee[]
  projects                    Project[]
  punchClockProfiles          PunchClockProfile[]
  punchClockProfilesMulti     PunchClockProfileDepartment[]
  categories                  DepartmentCategory[]
  categoriesManyMany          CategoryDepartment[]
  shifts                      Shift[]
  customers                   Customer[]
  invoices                    Invoice[]
  ledgerEntries               LedgerEntry[]
  employeesMulti              EmployeeDepartment[]
  roles                       RoleDepartment[]
  events                      EventDepartment[]
}

model DepartmentCategory {
  id           String               @id @default(cuid())
  name         String
  description  String?
  color        String?
  businessId   String
  departmentId String? // Deprecated: kept for backward compatibility
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  business     Business             @relation("BusinessCategories", fields: [businessId], references: [id], onDelete: Cascade)
  department   Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  functions    DepartmentFunction[]
  departments  CategoryDepartment[] // Many-to-many relation

  @@unique([name, businessId])
  @@index([businessId])
  @@index([departmentId])
}

// Junction table for many-to-many relationship between categories and departments
model CategoryDepartment {
  id           String             @id @default(cuid())
  categoryId   String
  departmentId String
  createdAt    DateTime           @default(now())
  category     DepartmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  department   Department         @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([categoryId, departmentId])
  @@index([categoryId])
  @@index([departmentId])
}

model DepartmentFunction {
  id             String             @id @default(cuid())
  name           String
  categoryId     String
  color          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  category       DepartmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  shifts         Shift[]
  employees      EmployeeFunction[]
  employeeGroups EmployeeGroup[]

  @@unique([name, categoryId])
  @@index([categoryId])
}

model EmployeeFunction {
  id         String             @id @default(cuid())
  employeeId String
  functionId String
  createdAt  DateTime           @default(now())
  employee   Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  function   DepartmentFunction @relation(fields: [functionId], references: [id], onDelete: Cascade)

  @@unique([employeeId, functionId])
  @@index([employeeId])
  @@index([functionId])
}

model PunchClockProfile {
  id             String                        @id @default(cuid())
  name           String
  departmentId   String?
  isActive       Boolean                       @default(true)
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @default(now())
  businessId     String
  activationCode String?
  business       Business                      @relation(fields: [businessId], references: [id])
  department     Department?                   @relation(fields: [departmentId], references: [id])
  departments    PunchClockProfileDepartment[]
  attendances    Attendance[]

  @@unique([name, businessId])
}

model PunchClockProfileDepartment {
  id                  String            @id @default(cuid())
  punchClockProfileId String
  departmentId        String
  createdAt           DateTime          @default(now())
  punchClockProfile   PunchClockProfile @relation(fields: [punchClockProfileId], references: [id], onDelete: Cascade)
  department          Department        @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([punchClockProfileId, departmentId])
  @@index([punchClockProfileId])
  @@index([departmentId])
}

model ProjectCategory {
  id       String    @id @default(cuid())
  name     String    @unique
  projects Project[] // One category can have many projects

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectFormSettings {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation("ProjectFormSettings", fields: [businessId], references: [id], onDelete: Cascade)
  deviceId   String?

  showCategory  Boolean @default(true)
  showCustomer  Boolean @default(true)
  showStartDate Boolean @default(true)
  showEndDate   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

model Project {
  id            String           @id @default(cuid())
  customerId    String?          @map("customer_id")
  customer      Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name          String // Prosjektnummer - project number/identifier
  projectNumber String?          @unique
  year          Int
  sequence      Int
  active        Boolean          @default(true) // Aktiv - checkbox to activate
  status        String? // Status (nullable)
  categoryId    String?          @map("category_id")
  category      ProjectCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  startDate     DateTime? // Startdato (nullable)
  endDate       DateTime? // Sluttdato (nullable)
  departmentId  String?
  department    Department?      @relation(fields: [departmentId], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @default(now())
  timeEntries   TimeEntry[]
  invoices      Invoice[]
  businessId    String
  business      Business         @relation(fields: [businessId], references: [id])
  ledgerEntries LedgerEntry[]
}

model TimeEntry {
  id           String    @id @default(cuid())
  employeeId   String
  projectId    String
  checkIn      DateTime
  checkOut     DateTime?
  gpsLatitude  Float?
  gpsLongitude Float?
  approved     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())
  employee     Employee  @relation(fields: [employeeId], references: [id])
  project      Project   @relation(fields: [projectId], references: [id])
}

model SickLeave {
  id         String   @id @default(cuid())
  employeeId String
  startDate  DateTime
  endDate    DateTime
  document   String?
  approved   Boolean  @default(false)
  status     SickLeaveStatus @default(PENDING)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  reason     String?
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Availability {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime
  isAvailable Boolean  @default(true)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
}

model WorkPlan {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime
  startTime  DateTime
  endTime    DateTime
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  breaks     Break[]
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Break {
  id         String   @id @default(cuid())
  workPlanId String
  startTime  DateTime
  endTime    DateTime
  duration   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  workPlan   WorkPlan @relation(fields: [workPlanId], references: [id])
}

model Shift {
  id              String              @id @default(cuid())
  date            DateTime
  startTime       String
  endTime         String?
  employeeId      String?
  employeeGroupId String?
  departmentId    String?
  shiftType       ShiftType
  shiftTypeId     String?
  breakStart      DateTime?
  breakEnd        DateTime?
  wage            Float
  wageType        WageType            @default(HOURLY)
  note            String?
  isPublished     Boolean             @default(false)
  approved        Boolean             @default(false)
  approvedAt      DateTime?
  approvedBy      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @default(now())
  breakPaid       Boolean             @default(false)
  status          ShiftStatus         @default(SCHEDULED)
  functionId      String?
  attendances     Attendance[]
  notifications   Notification[]
  department      Department?         @relation(fields: [departmentId], references: [id])
  employeeGroup   EmployeeGroup?      @relation(fields: [employeeGroupId], references: [id])
  employee        Employee?           @relation(fields: [employeeId], references: [id])
  shiftTypeConfig ShiftTypeConfig?    @relation(fields: [shiftTypeId], references: [id])
  function        DepartmentFunction? @relation(fields: [functionId], references: [id])
  shiftExchanges  ShiftExchange[]
  shiftRequests   ShiftRequest[]

  @@index([shiftTypeId])
  @@index([functionId])
  @@index([departmentId])
  @@index([date])
  @@index([employeeId])
  @@index([isPublished])
}

model ShiftExchange {
  id                 String         @id @default(cuid())
  shiftId            String
  fromEmployeeId     String
  toEmployeeId       String
  approvedAt         DateTime?
  approvedBy         String?
  createdAt          DateTime       @default(now())
  reason             String?
  requestedAt        DateTime       @default(now())
  status             String         @default("EMPLOYEE_PENDING")
  updatedAt          DateTime       @updatedAt
  type               String         @default("SWAP")
  employeeResponseAt DateTime?
  employeeResponseBy String?
  notifications      Notification[]
  fromEmployee       Employee       @relation("FromEmployee", fields: [fromEmployeeId], references: [id])
  shift              Shift          @relation(fields: [shiftId], references: [id])
  toEmployee         Employee       @relation("ToEmployee", fields: [toEmployeeId], references: [id])
}

model Invitation {
  id         String   @id @default(cuid())
  email      String   @unique
  token      String   @unique
  firstName  String?
  lastName   String?
  businessId String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id])
}

model PayrollPeriod {
  id             String              @id @default(cuid())
  name           String
  startDate      DateTime
  endDate        DateTime
  status         PayrollPeriodStatus @default(DRAFT)
  businessId     String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now())
  payrollEntries PayrollEntry[]
  business       Business            @relation(fields: [businessId], references: [id])

  @@unique([businessId, startDate, endDate])
}

model PayrollEntry {
  id              String             @id @default(cuid())
  employeeId      String
  payrollPeriodId String
  regularHours    Float              @default(0)
  overtimeHours   Float              @default(0)
  regularRate     Float
  overtimeRate    Float
  grossPay        Float
  deductions      Float              @default(0)
  netPay          Float
  bonuses         Float              @default(0)
  status          PayrollEntryStatus @default(DRAFT)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @default(now())
  employee        Employee           @relation(fields: [employeeId], references: [id])
  payrollPeriod   PayrollPeriod      @relation(fields: [payrollPeriodId], references: [id])

  @@unique([employeeId, payrollPeriodId])
}

model Attendance {
  id                  String             @id @default(cuid())
  employeeId          String
  businessId          String
  shiftId             String?
  punchClockProfileId String?
  punchInTime         DateTime
  punchOutTime        DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @default(now())
  approved            Boolean            @default(true)
  approvedAt          DateTime?
  approvedBy          String?
  business            Business           @relation(fields: [businessId], references: [id])
  employee            Employee           @relation(fields: [employeeId], references: [id])
  shift               Shift?             @relation(fields: [shiftId], references: [id])
  punchClockProfile   PunchClockProfile? @relation(fields: [punchClockProfileId], references: [id])

  @@index([punchClockProfileId])
}

model Notification {
  id              String           @id @default(cuid())
  type            NotificationType
  title           String
  message         String
  data            Json?
  recipientId     String?
  recipientUserId String?
  shiftExchangeId String?
  shiftId         String?
  contractId      String?
  isRead          Boolean          @default(false)
  readAt          DateTime?
  emailSent       Boolean          @default(false)
  emailSentAt     DateTime?
  emailError      String?
  smsSent         Boolean          @default(false)
  smsSentAt       DateTime?
  smsError        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now())
  recipient       Employee?        @relation("NotificationRecipient", fields: [recipientId], references: [id])
  recipientUser   User?            @relation("NotificationRecipientUser", fields: [recipientUserId], references: [id])
  shiftExchange   ShiftExchange?   @relation(fields: [shiftExchangeId], references: [id])
  shift           Shift?           @relation(fields: [shiftId], references: [id])
  contract        Contract?        @relation(fields: [contractId], references: [id])

  @@index([recipientId, isRead])
  @@index([recipientUserId, isRead])
  @@index([createdAt])
  @@index([contractId])
}

model PunchClockAccessSettings {
  id                     String            @id @default(cuid())
  businessId             String            @unique
  allowPunchFromAnywhere Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @default(now())
  allowedDepartments     String[]          @default([])
  restrictByDepartment   Boolean           @default(false)
  allowedLocations       AllowedLocation[]
  business               Business          @relation("PunchClockAccessSettings", fields: [businessId], references: [id])
}

model AllowedLocation {
  id            String                   @id @default(cuid())
  settingsId    String
  name          String
  address       String
  latitude      Float?
  longitude     Float?
  radius        Int                      @default(100)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @default(now())
  departmentIds String[]                 @default([])
  settings      PunchClockAccessSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model ContractTemplate {
  id              String        @id @default(cuid())
  name            String
  body            String
  logoPath        String?
  logoPosition    LogoPosition  @default(TOP_RIGHT)
  businessId      String
  employeeGroupId String
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now())
  contracts       Contract[]
  business        Business      @relation(fields: [businessId], references: [id])
  employeeGroup   EmployeeGroup @relation(fields: [employeeGroupId], references: [id])

  @@unique([name, businessId])
}

model SalaryCodeCategory {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  description String?
  icon        String?
  color       String?
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  salaryCodes SalaryCode[]
}

model SalaryCode {
  id                 String              @id @default(cuid())
  code               String
  name               String
  description        String?
  category           String              @default("HOURLY")
  categoryId         String?
  salaryCodeCategory SalaryCodeCategory? @relation(fields: [categoryId], references: [id])
  isActive           Boolean             @default(true)
  businessId         String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  payRules           PayRule[]
  business           Business            @relation(fields: [businessId], references: [id])

  @@unique([code, businessId])
  @@index([categoryId])
}

model PayRule {
  id                    String                 @id @default(cuid())
  name                  String
  description           String?
  ruleType              String
  salaryCodeId          String
