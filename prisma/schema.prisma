generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  password           String
  firstName          String
  lastName           String
  role               String              @default("USER")
  businessId         String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  pin                String?
  employees          Employee[]
  business           Business            @relation(fields: [businessId], references: [id])
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Business {
  id                       String                    @id @default(cuid())
  name                     String
  address                  String
  type                     String
  employeesCount           Int
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  currency                 String                    @default("USD")
  attendances              Attendance[]
  contracts                Contract[]
  contractTemplates        ContractTemplate[]
  departments              Department[]
  employeeGroups           EmployeeGroup[]
  invitations              Invitation[]
  payRules                 PayRule[]
  payrollPeriods           PayrollPeriod[]
  punchClockAccessSettings PunchClockAccessSettings? @relation("PunchClockAccessSettings")
  punchClockProfiles       PunchClockProfile[]
  salaryCodes              SalaryCode[]
  shiftTypes               ShiftTypeConfig[]
  users                    User[]
}

model Employee {
  id                  String               @id @default(cuid())
  userId              String
  firstName           String
  lastName            String
  birthday            DateTime
  sex                 Sex
  socialSecurityNo    String?              @unique
  address             String
  mobile              String
  employeeNo          String?              @unique
  bankAccount         String
  hoursPerMonth       Float?
  dateOfHire          DateTime
  isTeamLeader        Boolean              @default(false)
  departmentId        String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  employeeGroupId     String?
  email               String?              @unique
  profilePhoto        String?
  salaryRate          Float?
  attendances         Attendance[]
  availabilities      Availability[]
  contractsAsPerson   Contract[]           @relation("ContractPerson")
  contracts           Contract[]
  department          Department           @relation(fields: [departmentId], references: [id])
  employeeGroup       EmployeeGroup?       @relation("EmployeeToGroup", fields: [employeeGroupId], references: [id])
  user                User                 @relation(fields: [userId], references: [id])
  employeePayRules    EmployeePayRule[]
  notifications       Notification[]       @relation("NotificationRecipient")
  payrollEntries      PayrollEntry[]
  shifts              Shift[]
  fromShiftExchanges  ShiftExchange[]      @relation("FromEmployee")
  toShiftExchanges    ShiftExchange[]      @relation("ToEmployee")
  sickLeaves          SickLeave[]
  sickPayCalculations SickPayCalculation[]
  timeEntries         TimeEntry[]
  workPlans           WorkPlan[]
}

model EmployeeGroup {
  id                    String                 @id @default(cuid())
  name                  String
  hourlyWage            Float
  wagePerShift          Float
  defaultWageType       WageType               @default(HOURLY)
  salaryCode            String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now())
  businessId            String
  contracts             Contract[]
  contractTemplates     ContractTemplate[]
  employees             Employee[]             @relation("EmployeeToGroup")
  business              Business               @relation(fields: [businessId], references: [id])
  employeeGroupPayRules EmployeeGroupPayRule[]
  shifts                Shift[]

  @@unique([name, businessId])
}

model Contract {
  id                 String           @id @default(cuid())
  employeeId         String
  employeeGroupId    String
  contractTemplateId String
  startDate          DateTime
  endDate            DateTime?
  contractPersonId   String
  businessId         String
  signedStatus       String?          @default("UNSIGNED")
  signatureData      String?
  signedAt           DateTime?
  signedBy           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  business           Business         @relation(fields: [businessId], references: [id])
  contractPerson     Employee         @relation("ContractPerson", fields: [contractPersonId], references: [id])
  contractTemplate   ContractTemplate @relation(fields: [contractTemplateId], references: [id])
  employeeGroup      EmployeeGroup    @relation(fields: [employeeGroupId], references: [id])
  employee           Employee         @relation(fields: [employeeId], references: [id])
}

model Department {
  id                 String              @id @default(cuid())
  name               String
  address            String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now())
  address2           String?
  city               String
  country            String
  number             String?
  phone              String
  postCode           String?
  businessId         String
  business           Business            @relation(fields: [businessId], references: [id])
  employees          Employee[]
  projects           Project[]
  punchClockProfiles PunchClockProfile[]
}

model PunchClockProfile {
  id             String     @id @default(cuid())
  name           String
  departmentId   String
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now())
  businessId     String
  activationCode String?
  business       Business   @relation(fields: [businessId], references: [id])
  department     Department @relation(fields: [departmentId], references: [id])

  @@unique([name, businessId])
}

model Project {
  id           String      @id @default(cuid())
  name         String
  departmentId String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now())
  department   Department  @relation(fields: [departmentId], references: [id])
  timeEntries  TimeEntry[]
}

model TimeEntry {
  id           String    @id @default(cuid())
  employeeId   String
  projectId    String
  checkIn      DateTime
  checkOut     DateTime?
  gpsLatitude  Float?
  gpsLongitude Float?
  approved     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())
  employee     Employee  @relation(fields: [employeeId], references: [id])
  project      Project   @relation(fields: [projectId], references: [id])
}

model SickLeave {
  id         String   @id @default(cuid())
  employeeId String
  startDate  DateTime
  endDate    DateTime
  document   String?
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  reason     String?
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Availability {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime
  isAvailable Boolean  @default(true)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
}

model WorkPlan {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime
  startTime  DateTime
  endTime    DateTime
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  breaks     Break[]
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Break {
  id         String   @id @default(cuid())
  workPlanId String
  startTime  DateTime
  endTime    DateTime
  duration   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  workPlan   WorkPlan @relation(fields: [workPlanId], references: [id])
}

model Shift {
  id              String          @id @default(cuid())
  date            DateTime
  startTime       String
  endTime         String?
  employeeId      String?
  employeeGroupId String?
  shiftType       ShiftType
  breakStart      DateTime?
  breakEnd        DateTime?
  wage            Float
  wageType        WageType        @default(HOURLY)
  note            String?
  approved        Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now())
  breakPaid       Boolean         @default(false)
  status          ShiftStatus     @default(SCHEDULED)
  attendances     Attendance[]
  notifications   Notification[]
  employeeGroup   EmployeeGroup?  @relation(fields: [employeeGroupId], references: [id])
  employee        Employee?       @relation(fields: [employeeId], references: [id])
  shiftExchanges  ShiftExchange[]
}

model ShiftExchange {
  id                 String         @id @default(cuid())
  shiftId            String
  fromEmployeeId     String
  toEmployeeId       String
  approvedAt         DateTime?
  approvedBy         String?
  createdAt          DateTime       @default(now())
  reason             String?
  requestedAt        DateTime       @default(now())
  status             String         @default("EMPLOYEE_PENDING")
  updatedAt          DateTime       @updatedAt
  type               String         @default("SWAP")
  employeeResponseAt DateTime?
  employeeResponseBy String?
  notifications      Notification[]
  fromEmployee       Employee       @relation("FromEmployee", fields: [fromEmployeeId], references: [id])
  shift              Shift          @relation(fields: [shiftId], references: [id])
  toEmployee         Employee       @relation("ToEmployee", fields: [toEmployeeId], references: [id])
}

model Invitation {
  id         String   @id @default(cuid())
  email      String   @unique
  token      String   @unique
  firstName  String?
  lastName   String?
  businessId String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id])
}

model PayrollPeriod {
  id             String              @id @default(cuid())
  name           String
  startDate      DateTime
  endDate        DateTime
  status         PayrollPeriodStatus @default(DRAFT)
  businessId     String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now())
  payrollEntries PayrollEntry[]
  business       Business            @relation(fields: [businessId], references: [id])

  @@unique([businessId, startDate, endDate])
}

model PayrollEntry {
  id              String             @id @default(cuid())
  employeeId      String
  payrollPeriodId String
  regularHours    Float              @default(0)
  overtimeHours   Float              @default(0)
  regularRate     Float
  overtimeRate    Float
  grossPay        Float
  deductions      Float              @default(0)
  netPay          Float
  bonuses         Float              @default(0)
  status          PayrollEntryStatus @default(DRAFT)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @default(now())
  employee        Employee           @relation(fields: [employeeId], references: [id])
  payrollPeriod   PayrollPeriod      @relation(fields: [payrollPeriodId], references: [id])

  @@unique([employeeId, payrollPeriodId])
}

model Attendance {
  id           String    @id @default(cuid())
  employeeId   String
  businessId   String
  shiftId      String?
  punchInTime  DateTime
  punchOutTime DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())
  approved     Boolean   @default(true)
  approvedAt   DateTime?
  approvedBy   String?
  business     Business  @relation(fields: [businessId], references: [id])
  employee     Employee  @relation(fields: [employeeId], references: [id])
  shift        Shift?    @relation(fields: [shiftId], references: [id])
}

model Notification {
  id              String           @id @default(cuid())
  type            NotificationType
  title           String
  message         String
  data            Json?
  recipientId     String
  shiftExchangeId String?
  shiftId         String?
  isRead          Boolean          @default(false)
  readAt          DateTime?
  emailSent       Boolean          @default(false)
  emailSentAt     DateTime?
  emailError      String?
  smsSent         Boolean          @default(false)
  smsSentAt       DateTime?
  smsError        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now())
  recipient       Employee         @relation("NotificationRecipient", fields: [recipientId], references: [id])
  shiftExchange   ShiftExchange?   @relation(fields: [shiftExchangeId], references: [id])
  shift           Shift?           @relation(fields: [shiftId], references: [id])

  @@index([recipientId, isRead])
  @@index([createdAt])
}

model PunchClockAccessSettings {
  id                     String            @id @default(cuid())
  businessId             String            @unique
  allowPunchFromAnywhere Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @default(now())
  allowedDepartments     String[]          @default([])
  restrictByDepartment   Boolean           @default(false)
  allowedLocations       AllowedLocation[]
  business               Business          @relation("PunchClockAccessSettings", fields: [businessId], references: [id])
}

model AllowedLocation {
  id            String                   @id @default(cuid())
  settingsId    String
  name          String
  address       String
  latitude      Float?
  longitude     Float?
  radius        Int                      @default(100)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @default(now())
  departmentIds String[]                 @default([])
  settings      PunchClockAccessSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model ContractTemplate {
  id              String        @id @default(cuid())
  name            String
  body            String
  logoPath        String?
  logoPosition    LogoPosition  @default(TOP_RIGHT)
  businessId      String
  employeeGroupId String
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now())
  contracts       Contract[]
  business        Business      @relation(fields: [businessId], references: [id])
  employeeGroup   EmployeeGroup @relation(fields: [employeeGroupId], references: [id])

  @@unique([name, businessId])
}

model SalaryCode {
  id          String    @id @default(cuid())
  code        String
  name        String
  description String?
  category    String
  isActive    Boolean   @default(true)
  businessId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  payRules    PayRule[]
  business    Business  @relation(fields: [businessId], references: [id])

  @@unique([code, businessId])
}

model PayRule {
  id                    String                 @id @default(cuid())
  name                  String
  description           String?
  ruleType              String
  salaryCodeId          String
  isActive              Boolean                @default(true)
  businessId            String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now())
  employeeGroupPayRules EmployeeGroupPayRule[]
  employeePayRules      EmployeePayRule[]
  overtimeRule          OvertimeRule?
  business              Business               @relation(fields: [businessId], references: [id])
  salaryCode            SalaryCode             @relation(fields: [salaryCodeId], references: [id])

  @@unique([name, businessId])
}

model OvertimeRule {
  id                String   @id @default(cuid())
  payRuleId         String   @unique
  triggerAfterHours Decimal  @db.Decimal(5, 2)
  rateMultiplier    Decimal  @default(1.5) @db.Decimal(5, 2)
  isDaily           Boolean  @default(true)
  maxHoursPerDay    Decimal? @db.Decimal(5, 2)
  maxHoursPerWeek   Decimal? @db.Decimal(5, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  payRule           PayRule  @relation(fields: [payRuleId], references: [id], onDelete: Cascade)
}

model EmployeeGroupPayRule {
  id              String        @id @default(cuid())
  employeeGroupId String
  payRuleId       String
  baseRate        Decimal       @db.Decimal(10, 2)
  isDefault       Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now())
  employeeGroup   EmployeeGroup @relation(fields: [employeeGroupId], references: [id], onDelete: Cascade)
  payRule         PayRule       @relation(fields: [payRuleId], references: [id], onDelete: Cascade)

  @@unique([employeeGroupId, payRuleId])
}

model EmployeePayRule {
  id            String    @id @default(cuid())
  employeeId    String
  payRuleId     String
  customRate    Decimal   @db.Decimal(10, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payRule       PayRule   @relation(fields: [payRuleId], references: [id], onDelete: Cascade)

  @@index([employeeId, isActive])
}

model SickPayCalculation {
  id                String   @id @default(cuid())
  employeeId        String
  calculationDate   DateTime
  threeMonthAverage Decimal  @db.Decimal(10, 2)
  basePeriodStart   DateTime
  basePeriodEnd     DateTime
  totalHours        Decimal  @db.Decimal(10, 2)
  totalPay          Decimal  @db.Decimal(10, 2)
  dailyRate         Decimal  @db.Decimal(10, 2)
  hourlyRate        Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, calculationDate])
  @@index([employeeId, calculationDate])
}

model ShiftTypeConfig {
  id                  String             @id @default(cuid())
  name                String
  salaryCode          String
  payCalculationType  PayCalculationType
  payCalculationValue Decimal?           @db.Decimal(10, 2)
  description         String?
  businessId          String
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @default(now())
  business            Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([name, businessId])
  @@index([businessId, isActive])
}

enum WageType {
  HOURLY
  PER_SHIFT
}

enum Role {
  ADMIN
  HR_ADMIN
  KONTO_ADMIN
  VAKTPLAN_ADMIN
  EMPLOYEE
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum ShiftType {
  NORMAL
  ABSENT
  ARRIVED_LATE
  MEETING
  SICK
  TIME_OFF
  TRAINING
}

enum PayrollPeriodStatus {
  DRAFT
  FINALIZED
  CLOSED
}

enum PayrollEntryStatus {
  DRAFT
  APPROVED
  PAID
}

enum ShiftStatus {
  SCHEDULED
  WORKING
  COMPLETED
  CANCELLED
}

enum NotificationType {
  SHIFT_EXCHANGE_REQUEST
  SHIFT_EXCHANGE_ACCEPTED
  SHIFT_EXCHANGE_REJECTED
  SHIFT_EXCHANGE_APPROVED
  SHIFT_EXCHANGE_CANCELLED
  SHIFT_REMINDER
  SCHEDULE_UPDATED
  SYSTEM_ANNOUNCEMENT
}

enum LogoPosition {
  TOP_LEFT
  TOP_CENTER
  TOP_RIGHT
  BOTTOM_LEFT
  BOTTOM_CENTER
  BOTTOM_RIGHT
}

enum PayCalculationType {
  HOURLY_PLUS_FIXED
  FIXED_AMOUNT
  PERCENTAGE
  UNPAID
}
