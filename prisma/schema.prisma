model CustomerPayment {
  id          String        @id @default(cuid())
  customerId  String
  businessId  String
  paymentDate DateTime
  method      PaymentMethod
  amount      Decimal       @db.Decimal(10, 2)

  customer Customer @relation(fields: [customerId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  allocations PaymentAllocation[]

  voucherId String?  @unique
  voucher   Voucher? @relation(fields: [voucherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//pivot table of CustomerPayment and Invoice
model PaymentAllocation {
  id String @id @default(cuid())

  customerPaymentId String          @map("customer_payment_id")
  customerPayment   CustomerPayment @relation(fields: [customerPaymentId], references: [id], onDelete: Cascade)

  invoiceId String  @map("invoice_id")
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  amountAllocated Decimal @map("amount_allocated") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("payment_allocations")
}

enum VoucherType {
  INVOICE
  PAYMENT
  CREDIT_NOTE
  MANUAL
}

model Voucher {
  id            String      @id @default(cuid())
  businessId    String
  year          Int
  sequence      Int
  voucherNumber String      @unique
  type          VoucherType
  createdAt     DateTime    @default(now())

  business Business @relation(fields: [businessId], references: [id])

  ledgerEntries LedgerEntry[]
  invoice       Invoice?
  payment       CustomerPayment?

  @@unique([businessId, year, sequence])
  @@index([businessId, year, sequence])
}

