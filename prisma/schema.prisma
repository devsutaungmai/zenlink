}

model LedgerAccount {
  id            String      @id @default(cuid())
  accountNumber Int         @map("account_number")
  name          String      @map("name")
  type          AccountType @map("type")
  isActive      Boolean     @default(true) @map("is_active")

  // New fields from Excel
  vatCodeId             String?     @map("vat_code_id")              // Mva-kode
  vatCode               VatCode?    @relation("DefaultVatCode",fields: [vatCodeId], references: [id], onDelete: SetNull)
  vatSpecification      String?     @map("vat_specification")      // Mva-spesifikasjon
  reportGroup           String?     @map("report_group")           // Rapportgruppe
  saftStandardAccount   String?     @map("saft_standard_account")  // SAF-T standardkonto
  industrySpecification String?     @map("industry_specification") // Næringsspesifikasjon
  
  // Project and Department settings
  allowProject      Boolean @default(false) @map("allow_project")
  requireProject    Boolean @default(false) @map("require_project")
  allowDepartment   Boolean @default(false) @map("allow_department")
  requireDepartment Boolean @default(false) @map("require_department")

  // NULL businessId means it's a default/template account
  businessId String?   @map("business_id")
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  businessVatCodes BusinessLedgerAccountVatCode[]

  // Relations
  debitEntries          LedgerEntry[] @relation("DebitAccount")
  creditEntries         LedgerEntry[] @relation("CreditAccount")
  products              Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([accountNumber, businessId]) // Unique per business, or global if businessId is null
  @@map("ledger_accounts")
}

model BusinessLedgerAccountVatCode {
  id              String        @id @default(cuid())
  businessId      String        @map("business_id")
  ledgerAccountId String        @map("ledger_account_id")
  vatCodeId       String        @map("vat_code_id")
  
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  ledgerAccount  LedgerAccount @relation(fields: [ledgerAccountId], references: [id], onDelete: Cascade)
  vatCode        VatCode       @relation("CustomVatCode", fields: [vatCodeId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // A business can only have one custom VAT code per ledger account
  @@unique([businessId, ledgerAccountId])
  @@map("business_ledger_account_vat_codes")
}

model VatCode {
  id                      String    @id @default(cuid())
  code                    String    @map("code")                      // Kode (0, 1, 11, 12, etc.)
  name                    String    @map("name")                      // Navn
  rate                    Decimal   @map("rate") @db.Decimal(5, 2)    // Sats (0%, 25%, 15%, etc.)
  description             String    @map("description")               // Beskrivelse
  isActive                Boolean   @default(true) @map("is_active")  // Aktiv (Ja/Nei)
  
  // Date fields
  validFrom               DateTime? @map("valid_from")                // Gyldig fra
  validTo                 DateTime? @map("valid_to")                  // Gyldig til
  
  // Account references
  offsetAccountNumber     String?   @map("offset_account_number")     // Avgiftskonto
  settlementAccountNumber String?   @map("settlement_account_number") // Avsetningskonto
  
  // NULL businessId means it's a default/template VAT code
  businessId              String?   @map("business_id")
  business                Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  defaultForAccounts      LedgerAccount[] @relation("DefaultVatCode")

  // Custom VAT codes assigned by businesses
  businessLedgerAccounts  BusinessLedgerAccountVatCode[] @relation("CustomVatCode")
  
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  
  @@unique([code, businessId]) // Unique per business, or global if businessId is null
  @@map("vat_codes")
}

enum AccountType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  EQUITY
  APPROPRIATIONS
}

model LedgerEntry {
  id String @id @default(cuid())

  invoiceId String?  @map("invoice_id")
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  entryType LedgerEntryType @default(INVOICE_POST) @map("entry_type")

  documentDate DateTime? @map("document_date")
  postingDate  DateTime? @map("posting_date")
  amount       Decimal   @db.Decimal(10, 2)

  // Debit & Credit Accounts
  debitAccountId String?        @map("debit_account_id")
  debitAccount   LedgerAccount? @relation("DebitAccount", fields: [debitAccountId], references: [id], onDelete: SetNull)

  creditAccountId String?        @map("credit_account_id")
  creditAccount   LedgerAccount? @relation("CreditAccount", fields: [creditAccountId], references: [id], onDelete: SetNull)

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  businessId String   @map("business_id")
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  voucherId String
  voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ledger_entries")
}

enum LedgerEntryType {
  INVOICE_POST // When invoice is sent (group for 1500)
  PAYMENT_RECEIVED // When customer pays (don't group for 1500)
  CREDIT_NOTE // When credit note is issued (group for 1500)
  MANUAL_ADJUSTMENT // Manual entries
}

model InvoiceGeneralSetting {
  id          String   @id @default(cuid())
  businessId  String   @unique @map("business_id")
  business    Business @relation("InvoiceGeneralSetting", fields: [businessId], references: [id], onDelete: Cascade)

  // Invoice numbering settings
  firstInvoiceNumber    Int     @default(1) @map("first_invoice_number")
  firstCreditNoteNumber Int     @default(1) @map("first_credit_note_number")
  
  // Customer number series
  customerNumberSeriesStart Int? @default(10000)   @map("customer_number_series_start") // e.g., 10000
  customerNumberSeriesEnd   Int? @default(19999)   @map("customer_number_series_end")   // e.g., 19999
  nextCustomerNumber        Int? @map("next_customer_number")

  //Project number series
  projectNumberSeriesStart Int? @default(1000)    @map("project_number_series_start") // e.g., 1000
  projectNumberSeriesEnd   Int? @default(9999)    @map("project_number_series_end")   // e.g., 9999
  nextProjectNumber        Int? @map("next_project_number")

  //prouct number series
  productNumberSeriesStart Int? @default(1000)    @map("product_number_series_start") // e.g., 1000
  productNumberSeriesEnd   Int? @default(9999)    @map("product_number_series_end")   // e.g., 9999
  nextProductNumber        Int? @map("next_product_number")
  
  // Bank account settings
  defaultBankAccount        String? @map("default_bank_account")
  
  // Additional settings
  defaultPaymentTermsDays   Int?    @default(30) @map("default_payment_terms_days")
  defaultDueDays            Int?    @default(30) @map("default_due_days")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("invoice_general_settings")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique @map("invoice_number")
  year          Int          
  sequence      Int  
  invoiceDate   DateTime      @default(now()) @map("invoice_date")
  dueDate       DateTime?     @map("due_date")
  status        InvoiceStatus @default(DRAFT)

  // Customer relation
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  contactPersonId String?        @map("contact_person_id")
  contactPerson   ContactPerson? @relation(fields: [contactPersonId], references: [id], onDelete: SetNull)

  // Credit note relationship
  creditedInvoiceId String?   @map("credited_invoice_id")
  creditedInvoice   Invoice?  @relation("CreditNotes", fields: [creditedInvoiceId], references: [id], onDelete: SetNull)
  creditNotes       Invoice[] @relation("CreditNotes")

  // Summary calculations
  totalExclVAT  Decimal @map("total_excl_vat") @db.Decimal(10, 2)
  totalVatAmount Decimal @default(0) @map("total_vat_amount") @db.Decimal(10, 2)
  totalInclVAT  Decimal @map("total_incl_vat") @db.Decimal(10, 2)

  invoicepaymentTermsId String?              @map("invoice_payment_terms_id")
  InvoicePaymentTerms   InvoicePaymentTerms? @relation(fields: [invoicepaymentTermsId], references: [id], onDelete: SetNull)

  // Additional fields
  notes           String?
  sentAt          DateTime? @map("sent_at")
  paidAt          DateTime? @map("paid_at")
  dueDay          Int       @default(0)
  deliveryAddress String?   @map("delivery_address")

  // Relations
  invoiceLines InvoiceLine[]
  businessId   String        @map("business_id")
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)

  paymentAllocations PaymentAllocation[]

  ledgerEntries LedgerEntry[]

  voucherId String?  @unique
  voucher   Voucher? @relation(fields: [voucherId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([businessId, year, sequence])
  @@index([businessId, year, sequence])

  @@map("invoices")
}

model InvoiceLine {
  id        String  @id @default(cuid())
  invoiceId String  @map("invoice_id")
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Product relation
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  // Line item details
  quantity           Int      @default(0)
  pricePerUnit       Decimal  @map("price_per_unit") @db.Decimal(10, 2)
  discountPercentage Decimal? @default(0) @map("discount_percentage") @db.Decimal(5, 2)
  vatAmount          Decimal? @default(0) @map("vat_amount") @db.Decimal(10, 2)
  vatPercentage      Decimal? @default(0) @map("vat_percentage") @db.Decimal(5, 2)

  // Calculated fields (stored for history)
  subtotal       Decimal @map("subtotal") @db.Decimal(10, 2) // quantity × pricePerUnit
  discountAmount Decimal @map("discount_amount") @db.Decimal(10, 2)
  lineTotal      Decimal @map("line_total") @db.Decimal(10, 2) // subtotal - discountAmount

  // Product details snapshot (in case product changes later)
  productName   String  @map("product_name")
  productNumber String? @map("product_number")
  isCredited    Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("invoice_lines")
}

// Invoice Status Enum
enum InvoiceStatus {
  DRAFT // Not sent yet
  SENT // Sent to customer
  PAID // Payment received
  PARTIALLY_PAID // Partial payment received
  OVERDUE // Past due date
  CANCELLED // Cancelled
  OUTSTANDING //  sent and not paid yet
  CREDITED // Original invoice that was credited
  CREDIT_NOTE // Credit note issued
  PARTIALLY_CREDITED // Invoice that has some lines credited

  @@map("invoice_status")
}

// Payment Terms Model
model InvoicePaymentTerms {
  id                     String             @id @default(cuid())
  invoiceDueDateType     InvoiceDueDateType @default(DAYS_AFTER) @map("invoice_due_date_type")
  invoiceDueDateValue    Int                @default(14) @map("invoice_due_date_value") // 14 days, 1 month, etc.
  invoiceDueDateUnit     PaymentTimeUnit    @default(DAYS) @map("invoice_due_date_unit") // DAYS or MONTHS
  defaultDiscountPercent Decimal?           @default(0) @map("default_discount_percent") @db.Decimal(5, 2)

  // Relations
  customers  Customer[] // One payment term can be used by many customers
  invoices   Invoice[] // One payment term can be used by many invoices
  businessId String     @map("business_id")
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("invoice_payment_terms")
}

// Invoice Due Date Type Enum
enum InvoiceDueDateType {
  DAYS_AFTER // Calculate due date as X days/months after invoice date
  FIXED_DATE // Due date is always 1st of the month

  @@map("invoice_due_date_type")
}

// Payment Time Unit Enum
enum PaymentTimeUnit {
  DAYS
  MONTHS

  @@map("payment_time_unit")
}

